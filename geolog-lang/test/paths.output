-- elaborated
potential entry named Graph
type:  Theory
value:  sig
  V : Query
  E : V -> V -> Query
end
potential entry named Path
type:  (G : Graph) -> Theory
value:  G => sig
  t : G .V -> G .V -> Query
  empty : (x : G .V) -> t x x
  cons : (x : G .V) -> (y : G .V) -> (z : G .V) -> G .E x y -> t y z -> t x z
end
potential entry named Graph/hom
type:  (G0 : Graph) -> (G1 : Graph) -> Theory
value:  G0 => G1 => sig
  V : G0 .V -> G1 .V
  E : (x : G0 .V) -> (y : G0 .V) -> G0 .E x y -> G1 .E (V x) (V y)
end
potential entry named Path/hom
type:  (G : Graph) -> (P0 : Path G) -> (P1 : Path G) -> Theory
value:  G => P0 => P1 => sig
  t : (x : G .V) -> (y : G .V) -> P0 .t x y -> P1 .t x y
  empty : (x : G .V) -> t x x (P0 .empty x) = P1 .empty x
  cons : (x : G .V) -> (y : G .V) -> (z : G .V) -> (e : G .E x y) -> (p0 : P0 .t y z) -> t x z (P0 .cons x y z e p0) = P1 .cons x y z e (t y z p0)
end

