-- elaborated
global entry named Payload
type: Set
value: sig
  name : String
  rank : Int
end
global entry named T
type: Theory
value: sig
  X : Set
  payload : X -> Payload
  E : Payload -> Set
  edge : (x : X) -> E (payload x)
end
realm named TRealm
generators: node
  X = rel []
  payload = (fun [a : TRealm.X []] -> Payload)
  E = rel [a : Payload]
  edge = (fun [x : TRealm.X []] -> TRealm.E [a := TRealm.payload [a := x]])
end
lowered: flatrealm
  entities
    table ℜ.X := []
    table ℜ.payload := [.a : ℜ.X, .b.name : String, .b.rank : Int] primarykey [
      .a
    ]
    table ℜ.E := [.a.name : String, .a.rank : Int]
    table ℜ.edge := [.x : ℜ.X, .a : ℜ.E] primarykey [.x]
  end
  rules
    enforced ℜ.X.foreignKey := ℜ.X [] ⊢ ⊤
    enforced ℜ.payload.foreignKey a b.name b.rank := ℜ.payload [
      .a ↦ a,
      .b.name ↦ b.name,
      .b.rank ↦ b.rank
    ] ⊢ a ∈ ℜ.X []
    monitored ℜ.payload.total a := a ∈ ℜ.X [] ⊢ ℜ.payload [.a ↦ a]
    enforced ℜ.E.foreignKey a.name a.rank := ℜ.E [
      .a.name ↦ a.name,
      .a.rank ↦ a.rank
    ] ⊢ ⊤
    enforced ℜ.edge.foreignKey x a a.a.name.name a.a.name.rank a.a.rank.name a.a.rank.rank := ℜ.edge [
      .x ↦ x,
      .a ↦ a
    ] ∧ ℜ.payload [
      .a ↦ x,
      .b.name ↦ a.a.name.name,
      .b.rank ↦ a.a.name.rank
    ] ∧ ℜ.payload [
      .a ↦ x,
      .b.name ↦ a.a.rank.name,
      .b.rank ↦ a.a.rank.rank
    ] ⊢ x ∈ ℜ.X [] ∧ a ∈ ℜ.E [.a.name ↦ a.a.name.name, .a.rank ↦ a.a.rank.rank]
    monitored ℜ.edge.total x := x ∈ ℜ.X [] ⊢ ℜ.edge [.x ↦ x]
  end
end

-- messages
