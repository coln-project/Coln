-- elaborated
global entry named Graph
type: Theory
value: sig
  V : Set
  E : V -> V -> Set
end
global entry named Graph/hom
type: (G0 : Graph) -> (G1 : Graph) -> Theory
value: G0 => G1 => sig
  V : G0.V -> G1.V
  E : (v0 : G0.V) -> (v1 : G0.V) -> G0.E v0 v1 -> G1.E (V v0) (V v1)
end
global entry named GraphOfGraphs
type: Theory
value: sig
  base : Graph
  fiber : base.V -> Graph
  action : (v0 : base.V) -> (v1 : base.V) -> base.E v0 v1 -> Graph/hom (fiber v0) (fiber v1)
end
realm named GraphRealm
generators: node
  V = rel []
  E = rel [a : GraphRealm.V [], b : GraphRealm.V []]
end
lowered: flatrealm
  entities
    table ℜ.E := [.a : ℜ.V, .b : ℜ.V]
    table ℜ.V := []
  end
  rules
    enforced ℜ.foreignKey.E a b := ℜ.E [.a ↦ a, .b ↦ b] ⊢ a ∈ ℜ.V ∧ b ∈ ℜ.V
    enforced ℜ.foreignKey.V := ℜ.V ⊢ ⊤
  end
end
realm named GraphOfGraphsRealm
generators: node
  base = node
    V = rel []
    E = rel [a : GraphOfGraphsRealm.base.V [], b : GraphOfGraphsRealm.base.V []]
  end
  fiber = node
    V = rel [a : GraphOfGraphsRealm.base.V []]
    E = rel [ a : GraphOfGraphsRealm.base.V []
    , b : GraphOfGraphsRealm.fiber.V [a := a]
    , c : GraphOfGraphsRealm.fiber.V [a := a] ]
  end
  action = node
    V = (fun [ v0 : GraphOfGraphsRealm.base.V []
    , v1 : GraphOfGraphsRealm.base.V []
    , a : GraphOfGraphsRealm.base.E [a := v0, b := v1]
    , b : GraphOfGraphsRealm.fiber.V [ a := v0 ] ] -> GraphOfGraphsRealm.fiber.V [ a := v1 ])
    E = (fun [ v0 : GraphOfGraphsRealm.base.V []
    , v1 : GraphOfGraphsRealm.base.V []
    , a : GraphOfGraphsRealm.base.E [a := v0, b := v1]
    , v0/a : GraphOfGraphsRealm.fiber.V [a := v0]
    , v1/a : GraphOfGraphsRealm.fiber.V [a := v0]
    , b : GraphOfGraphsRealm.fiber.E [ a := v0
    , b := v0/a
    , c := v1/a ] ] -> GraphOfGraphsRealm.fiber.E [ a := v1
    , b := GraphOfGraphsRealm.action.V [v0 := v0, v1 := v1, a := a, b := v0/a]
    , c := GraphOfGraphsRealm.action.V [ v0 := v0
    , v1 := v1
    , a := a
    , b := v1/a ] ])
  end
end
lowered: flatrealm
  entities
    table ℜ.E.action := [ .v0 : ℜ.V.base
    , .v1 : ℜ.V.base
    , .a : ℜ.E.base
    , .v0/a : ℜ.V.fiber
    , .v1/a : ℜ.V.fiber
    , .b : ℜ.E.fiber
    , .c : ℜ.E.fiber ] primarykey [.a, .b, .v0, .v1, .v0/a, .v1/a]
    table ℜ.V.action := [ .v0 : ℜ.V.base
    , .v1 : ℜ.V.base
    , .a : ℜ.E.base
    , .b : ℜ.V.fiber
    , .c : ℜ.V.fiber ] primarykey [.a, .b, .v0, .v1]
    table ℜ.E.base := [.a : ℜ.V.base, .b : ℜ.V.base]
    table ℜ.V.base := []
    table ℜ.E.fiber := [.a : ℜ.V.base, .b : ℜ.V.fiber, .c : ℜ.V.fiber]
    table ℜ.V.fiber := [.a : ℜ.V.base]
  end
  rules
    enforced ℜ.foreignKey.E.action v0 v1 a v0/a v1/a b c c.b c.c := ℜ.E.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .v0/a ↦ v0/a
    , .v1/a ↦ v1/a
    , .b ↦ b
    , .c ↦ c ] ∧ ℜ.V.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .b ↦ v0/a
    , .c ↦ c.b ] ∧ ℜ.V.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .b ↦ v1/a
    , .c ↦ c.c ] ⊢ v0 ∈ ℜ.V.base ∧ v1 ∈ ℜ.V.base ∧ a ∈ ℜ.E.base [ .a ↦ v0
    , .b ↦ v1 ] ∧ v0/a ∈ ℜ.V.fiber [ .a ↦ v0 ] ∧ v1/a ∈ ℜ.V.fiber [ .a ↦ v0 ] ∧ b ∈ ℜ.E.fiber [ .a ↦ v0
    , .b ↦ v0/a
    , .c ↦ v1/a ] ∧ c ∈ ℜ.E.fiber [.a ↦ v1, .b ↦ c.b, .c ↦ c.c]
    monitored ℜ.total.E.action v0 v1 a v0/a v1/a b := v0 ∈ ℜ.V.base ∧ v1 ∈ ℜ.V.base ∧ a ∈ ℜ.E.base [ .a ↦ v0
    , .b ↦ v1 ] ∧ v0/a ∈ ℜ.V.fiber [ .a ↦ v0 ] ∧ v1/a ∈ ℜ.V.fiber [ .a ↦ v0 ] ∧ b ∈ ℜ.E.fiber [ .a ↦ v0
    , .b ↦ v0/a
    , .c ↦ v1/a ] ⊢ ℜ.E.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .v0/a ↦ v0/a
    , .v1/a ↦ v1/a
    , .b ↦ b ]
    enforced ℜ.foreignKey.V.action v0 v1 a b c := ℜ.V.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .b ↦ b
    , .c ↦ c ] ⊢ v0 ∈ ℜ.V.base ∧ v1 ∈ ℜ.V.base ∧ a ∈ ℜ.E.base [ .a ↦ v0
    , .b ↦ v1 ] ∧ b ∈ ℜ.V.fiber [.a ↦ v0] ∧ c ∈ ℜ.V.fiber [.a ↦ v1]
    monitored ℜ.total.V.action v0 v1 a b := v0 ∈ ℜ.V.base ∧ v1 ∈ ℜ.V.base ∧ a ∈ ℜ.E.base [ .a ↦ v0
    , .b ↦ v1 ] ∧ b ∈ ℜ.V.fiber [.a ↦ v0] ⊢ ℜ.V.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .b ↦ b ]
    enforced ℜ.foreignKey.E.base a b := ℜ.E.base [ .a ↦ a
    , .b ↦ b ] ⊢ a ∈ ℜ.V.base ∧ b ∈ ℜ.V.base
    enforced ℜ.foreignKey.V.base := ℜ.V.base ⊢ ⊤
    enforced ℜ.foreignKey.E.fiber a b c := ℜ.E.fiber [ .a ↦ a
    , .b ↦ b
    , .c ↦ c ] ⊢ a ∈ ℜ.V.base ∧ b ∈ ℜ.V.fiber [.a ↦ a] ∧ c ∈ ℜ.V.fiber [.a ↦ a]
    enforced ℜ.foreignKey.V.fiber a := ℜ.V.fiber [.a ↦ a] ⊢ a ∈ ℜ.V.base
  end
end

-- messages
