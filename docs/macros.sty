\ProvidesPackage{macros}

\usepackage{fontspec}
\setmonofont[Path=fonts/, Scale=MatchLowercase]{Inconsolata-Regular}

\RequirePackage{amsthm}
\RequirePackage{amsmath}
\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=blue,
    urlcolor=blue,
    filecolor=blue,
    citecolor=blue,
    pdftitle={Geolog core},
    pdfpagemode=FullScreen,
    }
\RequirePackage{cleveref}
\RequirePackage{stmaryrd}
\RequirePackage{tikz-cd}
\RequirePackage{quiver}
\RequirePackage{mathpartir}

\RequirePackage[final]{microtype}
\RequirePackage{natbib}

\RequirePackage{newpxtext}
\RequirePackage{newpxmath}

\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[section]

\theoremstyle{definition}
\newtheorem{construction}[theorem]{Construction}
\crefname{construction}{Construction}{Constructions}
\newtheorem{definition}[theorem]{Definition}
\crefname{definition}{Definition}{Definitions}
\newtheorem{example}[theorem]{Example}
\crefname{example}{Example}{Examples}
\newtheorem{interpretation}[theorem]{Interpretation}
\crefname{interpretation}{Interpretation}{Interpretations}
% AucTeX indents "description" weirdly, I think because of description lists
\newtheorem{xdescription}[theorem]{Description}
\crefname{xdescription}{Description}{Descriptions}
\newtheorem{remark}[theorem]{Remark}
\crefname{remark}{Remark}{Remarks}
\newtheorem{thesis}[theorem]{Thesis}
\crefname{thesis}{Thesis}{Theses}
\newtheorem{notes}[theorem]{Notes}
\crefname{notes}{Notes}{Notes}
\newtheorem{ttrule}[theorem]{Rule}
\crefname{ttrule}{Rule}{Rules}
\newtheorem{problem}[theorem]{Problem}
\crefname{problem}{Problem}{Problems}
\newtheorem{warning}[theorem]{Warning}
\crefname{warning}{Warning}{Warnings}
\newtheorem{question}{Question}
\crefname{question}{Question}{Questions}

\NewDocumentCommand\defcase{m}{\textbf{#1}}

\NewDocumentCommand\mb{m}{\mathbf{#1}}
\NewDocumentCommand\mc{m}{\mathcal{#1}}
\NewDocumentCommand\ms{m}{\mathsf{#1}}

\NewDocumentCommand\op{}{^\mathrm{op}}

\NewDocumentCommand\sem{m}{\left\llbracket#1\right\rrbracket}
\NewDocumentCommand\yields{}{\vdash}
\NewDocumentCommand\tri{}{\triangleright}
\NewDocumentCommand\jdg{m}{\;\mathsf{#1}}
\NewDocumentCommand\jctx{}{\jdg{ctx}}
\NewDocumentCommand\jtype{}{\jdg{type}}
\NewDocumentCommand\subst{}{\setminus}
\NewDocumentCommand\locks{}{\ms{locks}}
\NewDocumentCommand\bindvia{m}{\mathrel{{:}^{#1}}}
\NewDocumentCommand\llet{}{\ms{let}\:}
\NewDocumentCommand\inn{}{\:\ms{in}\:}
\DeclareMathOperator\init{\ms{init}}

\NewDocumentCommand\xto{m}{\xrightarrow{#1}}
\NewDocumentCommand\To{}{\Rightarrow}
\NewDocumentCommand\ot{}{\leftarrow}
\NewDocumentCommand\into{}{\hookrightarrow}

\NewDocumentCommand\ZZ{}{\mathbb{Z}}
\NewDocumentCommand\NN{}{\mathbb{N}}

\NewDocumentCommand\groth{}{\textstyle{\int}}
\NewDocumentCommand\Trunc{m}{\left\llbracket #1 \right\rrbracket}
