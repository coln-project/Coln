type V
type E: V -> V -> Type

theory Graph := sig
  V : Set
  E : V -> V -> Set
  Q : E -> E -> Set
end

vertices
1
2
3

edges
v1 v2
v2 v3



theory Graph/hom (G0 : Graph) (G1 : Graph) := sig
  V : G0.V -> G1.V
  E : (x : G0.V) -> (y : G0.V) -> G0.E x y -> (G1.E (V x) (V y))
end

theory Path (G : Graph) := sig
  t : G.V -> G.V -> Set
  empty : (x : G.V) -> t x x
  cons : (
    (x : G.V) ->
    (y : G.V) ->
    (z : G.V) ->
    G.E x y ->
    t y z ->
    t x z
  )
end

theory Path/hom (G : Graph) (P0 : Path G) (P1 : Path G) := sig
  t : (x : G.V) -> (y : G.V) -> P0.t x y -> P1.t x y
  empty : (x : G.V) -> t x x (P0.empty x) = P1.empty x
  cons : (
    (x : G.V) ->
    (y : G.V) ->
    (z : G.V) ->
    (e : G.E x y) ->
    (p0 : P0.t y z) ->
    t x z (P0.cons x y z e p0) = P1.cons x y z e (t y z p0)
  )
end

theory Main := sig
  Graphs : Set
  G : Graphs -> Graph
  G0 : Graphs
  G1 : Graphs
  Hom : Graph/hom (G G0) (G G1)
  Path0 : Path (G G0)
  Path1 : Path (G G0)
  PathHom : Path/hom (G G0) Path0 Path1
end

realm Path @ Main

end
