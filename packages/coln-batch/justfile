# Task runner: https://github.com/casey/just
# From packages/coln-batch, with Rust on PATH (e.g. `nix develop`):
#   just              # list available recipes
#   just check        # fmt-check + clippy + test

crate := "coln-batch"

default:
    @just --list

fmt:
    cargo fmt -p {{crate}}

fmt-check:
    cargo fmt -p {{crate}} --check

clippy:
    cargo clippy -p {{crate}} --all-targets --all-features -- -D warnings

test:
    cargo test -p {{crate}} --all-targets

import:
    cargo fix -p {{crate}} --all-targets --all-features --allow-dirty --allow-staged

fix: import fmt

check: fmt-check clippy test

ci: check

smoke:
    cargo run -p {{crate}} --example smoke

demo:
    cargo run -p {{crate}} --example demo --release
