theory MathieuTemplate := sig
  Point : Set
  Quad : Set   # Ordered 4-tuples of distinct points

  # Quadruple projections
  q0 : Quad -> Point
  q1 : Quad -> Point
  q2 : Quad -> Point
  q3 : Quad -> Point

  # Group action
  act : Quad -> Point -> Point

  # Group multiplication
  mul : Quad -> Quad -> Quad

  # Base point markers (p0, p1, p2, p3 form the canonical base 4-tuple)
  base0 : Point
  base1 : Point
  base2 : Point
  base3 : Point

  # === Axioms ===

  make_quad: Point -> Point -> Point -> Point -> Quad

  # Identifying each quad with its quartet of distinct coordinates
  ax/quad_gen : (a : Point) -> (b : Point) -> (c : Point) -> (d : Point) -> (
    (a = b) \/ (b = c) \/ (a = c) \/ (a = d) \/ (b = d) \/ (c = d) \/ (
      (q0 (make_quad a b c d) = a) /\ 
      (q1 (make_quad a b c d) = b) /\ 
      (q2 (make_quad a b c d) = c) /\
      (q3 (make_quad a b c d) = d)
    )
  )

  ax/sharp : (q : Quad) -> q = make_quad (q0 q) (q1 q) (q2 q) (q3 q)

  # Each quadruple acts as indicated on the base points
  ax/quad_acts_basepoints : (q : Quad) -> (b : Point) -> (
    (act q base0 = q0 q) /\
    (act q base1 = q1 q) /\
    (act q base2 = q2 q) /\
    (act q base3 = q3 q)
  )

  # Action respects multiplication
  ax/act_mul : (q : Quad) -> (r : Quad) -> p : Point -> act (mul q r) p = act q (act r p)

  # Associativity of multiplication
  ax/mul_assoc : (q : Quad) -> (r : Quad) -> (s : Quad) -> mul (mul q r) s  = mul q (mul r s)

end

