-- elaborated
global entry named Pair
in mode: Conjunctive
type: Set
value: sig
  first : Int
  second : Int
end
global entry named T
in mode: Conjunctive
type: Theory
value: sig
  E : Int -> Int -> Set
  R : (p : Pair) -> E p.second p.first -> Set
end
realm named TRealm
generators: node
  E = rel [a : Int, b : Int]
  R = rel [p : Pair, a : TRealm.E [a := p.second, b := p.first]]
end
lowered: flatrealm
  entities
    table ℜ.E := [.a : Int, .b : Int]
    table ℜ.R := [.p.first : Int, .p.second : Int, .a : ℜ.E]
  end
  rules
    enforced ℜ.E.foreignKey a b := ℜ.E [.a ↦ a, .b ↦ b] ⊢ ⊤
    enforced ℜ.R.foreignKey p.first p.second a := ℜ.R [
      .p.first ↦ p.first,
      .p.second ↦ p.second,
      .a ↦ a
    ] ⊢ a ∈ ℜ.E [.a ↦ p.second, .b ↦ p.first]
  end
end

-- messages
