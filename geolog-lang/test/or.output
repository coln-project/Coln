-- elaborated
potential entry named BinaryCocone
type:  (p : Set) *-> (q : Set) *-> Theory
value:  p => q => sig
  apex : Set
  inl : p *-> apex
  inr : q *-> apex
end
kinetic entry named Either
type: (a : Set) *-> (b : Set) *-> Inductive Set
value: a => b => pure (Either/cocone a b .use .apex)
kinetic entry named Either/cocone
type: (a : Set) *-> (b : Set) *-> Inductive (BinaryCocone a b)
value: a => b => init (BinaryCocone a b)

