-- elaborated
potential entry named Cocone
type:  (a : Set) *-> (b : Set) *-> Theory
value:  a => b => sig
  apex : Set
  inl : a *-> apex
  inr : b *-> apex
end
kinetic entry named Either
type: (a : Set) *-> (b : Set) *-> Inductive Set
value: a => b => pure (Either/cocone a b .use .apex)
kinetic entry named Either/cocone
type: (a : Set) *-> (b : Set) *-> Inductive (Cocone a b)
value: a => b => init (Cocone a b)

