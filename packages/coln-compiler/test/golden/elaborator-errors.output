  second : Int
end
global entry named pair
type: Pair
value: [first := 1, second := 2]
global entry named Dependent
type: Theory
value: sig
  A : Set
  value : A
end
global entry named dependent
type: Dependent
value: [A := Int, value := 1]
global entry named identity
type: Int -> Int
value: x => x
global entry named shadow
type: (x : String) -> Int -> Int
value: x => x => x

