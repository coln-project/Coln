theory Graph := sig
  V : Set
  E : V -> V -> Set
end

realm Graph @ Graph
  def free-edge : Set := sig
    v0 : self.V
    v1 : self.V
    f : self.E v0 v1
  end
end

theory Graph/hom (G0 : Graph) (G1 : Graph) := sig
  V : G0.V -> G1.V
  E : (v0 : G0.V) -> (v1 : G0.V) -> G0.E v0 v1 -> G1.E (V v0) (V v1)
end

theory GraphOfGraphs := sig
  base : Graph
  fiber : base.V -> Graph
  action : (v0 : base.V) -> (v1 : base.V) -> base.E v0 v1 -> Graph/hom (fiber v0) (fiber v1)
end

realm GraphOfGraphs @ GraphOfGraphs
end
