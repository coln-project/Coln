theory IdempotentSemigroup := sig
  Element : Query

  # Multiplication as a function
  mul : (x : Element) -> (y : Element) -> Element

  mul/idempotent : (x : Element) -> mul x x = x

  mul/assoc : (x : Element) -> (y : Element) -> (z : Element) -> (mul (mul x y) z) = (mul x (mul y z))
end

