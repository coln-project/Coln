-- elaborated
global entry named Truth
type: Prop
value: sig
end
global entry named T
type: Theory
value: sig
  truth : Truth
end
realm named TRealm
generators: node
  truth = (fun [] -> Truth)
end
lowered: flatrealm
  entities
    table ℜ.truth := [] primarykey []
  end
  rules
    enforced ℜ.truth.foreignKey := ℜ.truth [] ⊢ ⊤
    monitored ℜ.truth.total := ⊤ ⊢ ℜ.truth []
  end
end

-- messages
