-- elaborated
global entry named Payload
in mode: Conjunctive
type: Set
value: sig
  name : String
  rank : Int
end
global entry named T
in mode: Conjunctive
type: Theory
value: sig
  X : Set
  payload : X -> Payload
  E : Int -> Set
  edge : (x : X) -> E (payload x .rank)
end
realm named TRealm
generators: node
  X = rel []
  payload = (fun [a : TRealm.X []] -> Payload)
  E = rel [a : Int]
  edge = (fun [x : TRealm.X []] -> TRealm.E [
    a := TRealm.payload [a := x] .rank
  ])
end
lowered: flatrealm
  entities
    table ℜ.X := []
    table ℜ.payload := [.a : ℜ.X, .b.name : String, .b.rank : Int] primarykey [
      .a
    ]
    table ℜ.E := [.a : Int]
    table ℜ.edge := [.x : ℜ.X, .a : ℜ.E] primarykey [.x]
  end
  rules
    enforced ℜ.X.foreignKey := ℜ.X [] ⊢ ⊤
    enforced ℜ.payload.foreignKey a b.name b.rank := ℜ.payload [
      .a ↦ a,
      .b.name ↦ b.name,
      .b.rank ↦ b.rank
    ] ⊢ a ∈ ℜ.X []
    monitored ℜ.payload.total a := a ∈ ℜ.X [] ⊢ ℜ.payload [.a ↦ a]
    enforced ℜ.E.foreignKey a := ℜ.E [.a ↦ a] ⊢ ⊤
    enforced ℜ.edge.foreignKey x a a.a.name a.a.rank := ℜ.edge [
      .x ↦ x,
      .a ↦ a
    ] ∧ ℜ.payload [
      .a ↦ x,
      .b.name ↦ a.a.name,
      .b.rank ↦ a.a.rank
    ] ⊢ x ∈ ℜ.X [] ∧ a ∈ ℜ.E [.a ↦ a.a.rank]
    monitored ℜ.edge.total x := x ∈ ℜ.X [] ⊢ ℜ.edge [.x ↦ x]
  end
end

-- messages
