-- elaborated
global entry named Key
type: Set
value: sig
  rank : Int
end
global entry named Payload
type: Set
value: sig
  name : String
end
global entry named T
type: Theory
value: sig
  X : Set
  key : X -> Key
  payload : Int -> Payload
  E : String -> Set
  edge : (x : X) -> E (payload (key x .rank) .name)
end
realm named TRealm
generators: node
  X = rel []
  key = (fun [a : TRealm.X []] -> Key)
  payload = (fun [a : Int] -> Payload)
  E = rel [a : String]
  edge = (fun [x : TRealm.X []] -> TRealm.E [
    a := TRealm.payload [a := TRealm.key [a := x] .rank] .name
  ])
end
lowered: flatrealm
  entities
    table ℜ.X := []
    table ℜ.key := [.a : ℜ.X, .b.rank : Int] primarykey [.a]
    table ℜ.payload := [.a : Int, .b.name : String] primarykey [.a]
    table ℜ.E := [.a : String]
    table ℜ.edge := [.x : ℜ.X, .a : ℜ.E] primarykey [.x]
  end
  rules
    enforced ℜ.X.foreignKey := ℜ.X [] ⊢ ⊤
    enforced ℜ.key.foreignKey a b.rank := ℜ.key [
      .a ↦ a,
      .b.rank ↦ b.rank
    ] ⊢ a ∈ ℜ.X []
    monitored ℜ.key.total a := a ∈ ℜ.X [] ⊢ ℜ.key [.a ↦ a]
    enforced ℜ.payload.foreignKey a b.name := ℜ.payload [
      .a ↦ a,
      .b.name ↦ b.name
    ] ⊢ ⊤
    monitored ℜ.payload.total a := ⊤ ⊢ ℜ.payload [.a ↦ a]
    enforced ℜ.E.foreignKey a := ℜ.E [.a ↦ a] ⊢ ⊤
    enforced ℜ.edge.foreignKey x a a.a.name a.a.a.rank := ℜ.edge [
      .x ↦ x,
      .a ↦ a
    ] ∧ ℜ.key [.a ↦ x, .b.rank ↦ a.a.a.rank] ∧ ℜ.payload [
      .a ↦ a.a.a.rank,
      .b.name ↦ a.a.name
    ] ⊢ x ∈ ℜ.X [] ∧ a ∈ ℜ.E [.a ↦ a.a.name]
    monitored ℜ.edge.total x := x ∈ ℜ.X [] ⊢ ℜ.edge [.x ↦ x]
  end
end

-- messages
