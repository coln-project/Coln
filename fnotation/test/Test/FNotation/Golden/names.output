-- pretty
let `+` x y := plus x y
let `+`/comm := plus/comm
theory errant/nonsense := sig
  this : that
  <error> : '`import`/`sig` .`<>`
  bean/outsider : `😎`
  think/different : `^^^`
  never : ``/mind
end

