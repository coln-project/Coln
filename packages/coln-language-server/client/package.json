{
  "name": "geolog-lsp-client",
  "displayName": "Geolog LSP Client",
  "description": "VS Code/Cursor client for the Geolog language server",
  "version": "0.1.0",
  "publisher": "geolog-developers",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:geolog"],
  "main": "out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "geolog",
        "extensions": [".glog", ".geolog"],
        "aliases": ["Geolog", "glog"]
      }
    ],
    "configurationDefaults": {
      "[geolog]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "configuration": {
      "title": "Geolog LSP",
      "properties": {
        "geolog-lsp.server.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the geolog-lsp server binary, or path relative to the extension. Leave empty to auto-detect from workspace or extension folder."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -w -p ."
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "vscode-languageclient": "^9.0.1"
  }
}