-- elaborated
global entry named Family
in mode: Conjunctive
type: Theory
value: sig
  person : Set
  is-parent : person -> person -> Prop
  happy : Prop
end
global entry named HP
in mode: Conjunctive
type: Theory
value: sig
  person : Set
  voldemort : person
  tomriddle : person
  reveal : voldemort = tomriddle
end
global entry named Unit
in mode: Conjunctive
type: Prop
value: sig
end
global entry named P
in mode: Conjunctive
type: Theory
value: sig
  u : Unit
end

