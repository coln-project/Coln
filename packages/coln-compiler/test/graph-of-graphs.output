-- elaborated
global entry named Graph
type: Theory
value: sig
  V : Set
  E : V -> V -> Set
end
global entry named Graph/hom
type: (G0 : Graph) -> (G1 : Graph) -> Theory
value: G0 => G1 => sig
  V : G0.V -> G1.V
  E : (v0 : G0.V) -> (v1 : G0.V) -> G0.E v0 v1 -> G1.E (V v0) (V v1)
end
global entry named GraphOfGraphs
type: Theory
value: sig
  base : Graph
  fiber : base.V -> Graph
  action : (v0 : base.V) -> (v1 : base.V) -> base.E v0 v1 -> Graph/hom (fiber v0) (fiber v1)
end
realm named GraphRealm
generators: node
  V = rel []
  E = rel [a : GraphRealm.V [], b : GraphRealm.V []]
end
lowered: flatrealm
  entities
    table GraphRealm.E := [.a : GraphRealm.V, .b : GraphRealm.V]
    table GraphRealm.V := []
  end
  rules
    enforced GraphRealm.foreignKey.E := ∀ [a, b] ([ GraphRealm.E [ .a ↦ a
    , .b ↦ b ] ] -> [(GraphRealm.V @ a) [], (GraphRealm.V @ b) []])
    enforced GraphRealm.foreignKey.V := ∀ [] ([GraphRealm.V []] -> [])
  end
end
realm named GraphOfGraphsRealm
generators: node
  base = node
    V = rel []
    E = rel [a : GraphOfGraphsRealm.base.V [], b : GraphOfGraphsRealm.base.V []]
  end
  fiber = node
    V = rel [a : GraphOfGraphsRealm.base.V []]
    E = rel [ a : GraphOfGraphsRealm.base.V []
    , b : GraphOfGraphsRealm.fiber.V [a := a]
    , c : GraphOfGraphsRealm.fiber.V [a := a] ]
  end
  action = node
    V = (fun [ v0 : GraphOfGraphsRealm.base.V []
    , v1 : GraphOfGraphsRealm.base.V []
    , a : GraphOfGraphsRealm.base.E [a := v0, b := v1]
    , b : GraphOfGraphsRealm.fiber.V [ a := v0 ] ] -> GraphOfGraphsRealm.fiber.V [ a := v1 ])
    E = (fun [ v0 : GraphOfGraphsRealm.base.V []
    , v1 : GraphOfGraphsRealm.base.V []
    , a : GraphOfGraphsRealm.base.E [a := v0, b := v1]
    , v0/a : GraphOfGraphsRealm.fiber.V [a := v0]
    , v1/a : GraphOfGraphsRealm.fiber.V [a := v0]
    , b : GraphOfGraphsRealm.fiber.E [ a := v0
    , b := v0/a
    , c := v1/a ] ] -> GraphOfGraphsRealm.fiber.E [ a := v1
    , b := GraphOfGraphsRealm.action.V [v0 := v0, v1 := v1, a := a, b := v0/a]
    , c := GraphOfGraphsRealm.action.V [ v0 := v0
    , v1 := v1
    , a := a
    , b := v1/a ] ])
  end
end
lowered: flatrealm
  entities
    table GraphOfGraphsRealm.E.action := [ .v0 : GraphOfGraphsRealm.V.base
    , .v1 : GraphOfGraphsRealm.V.base
    , .a : GraphOfGraphsRealm.E.base
    , .v0/a : GraphOfGraphsRealm.V.fiber
    , .v1/a : GraphOfGraphsRealm.V.fiber
    , .b : GraphOfGraphsRealm.E.fiber
    , .c : GraphOfGraphsRealm.E.fiber ] primarykey [ .a
    , .b
    , .v0
    , .v1
    , .v0/a
    , .v1/a ]
    table GraphOfGraphsRealm.V.action := [ .v0 : GraphOfGraphsRealm.V.base
    , .v1 : GraphOfGraphsRealm.V.base
    , .a : GraphOfGraphsRealm.E.base
    , .b : GraphOfGraphsRealm.V.fiber
    , .c : GraphOfGraphsRealm.V.fiber ] primarykey [.a, .b, .v0, .v1]
    table GraphOfGraphsRealm.E.base := [ .a : GraphOfGraphsRealm.V.base
    , .b : GraphOfGraphsRealm.V.base ]
    table GraphOfGraphsRealm.V.base := []
    table GraphOfGraphsRealm.E.fiber := [ .a : GraphOfGraphsRealm.V.base
    , .b : GraphOfGraphsRealm.V.fiber
    , .c : GraphOfGraphsRealm.V.fiber ]
    table GraphOfGraphsRealm.V.fiber := [.a : GraphOfGraphsRealm.V.base]
  end
  rules
    enforced GraphOfGraphsRealm.foreignKey.E.action := ∀ [ v0
    , v1
    , a
    , v0/a
    , v1/a
    , b
    , c
    , c.b
    , c.c ] ([ GraphOfGraphsRealm.E.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .v0/a ↦ v0/a
    , .v1/a ↦ v1/a
    , .b ↦ b
    , .c ↦ c ]
    , GraphOfGraphsRealm.V.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .b ↦ v0/a
    , .c ↦ c.b ]
    , GraphOfGraphsRealm.V.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .b ↦ v1/a
    , .c ↦ c.c ] ] -> [ (GraphOfGraphsRealm.V.base @ v0) []
    , (GraphOfGraphsRealm.V.base @ v1) []
    , (GraphOfGraphsRealm.E.base @ a) [.a ↦ v0, .b ↦ v1]
    , (GraphOfGraphsRealm.V.fiber @ v0/a) [.a ↦ v0]
    , (GraphOfGraphsRealm.V.fiber @ v1/a) [.a ↦ v0]
    , (GraphOfGraphsRealm.E.fiber @ b) [.a ↦ v0, .b ↦ v0/a, .c ↦ v1/a]
    , (GraphOfGraphsRealm.E.fiber @ c) [.a ↦ v1, .b ↦ c.b, .c ↦ c.c] ])
    monitored GraphOfGraphsRealm.total.E.action := ∀ [ v0
    , v1
    , a
    , v0/a
    , v1/a
    , b ] ([ (GraphOfGraphsRealm.V.base @ v0) []
    , (GraphOfGraphsRealm.V.base @ v1) []
    , (GraphOfGraphsRealm.E.base @ a) [.a ↦ v0, .b ↦ v1]
    , (GraphOfGraphsRealm.V.fiber @ v0/a) [.a ↦ v0]
    , (GraphOfGraphsRealm.V.fiber @ v1/a) [.a ↦ v0]
    , (GraphOfGraphsRealm.E.fiber @ b) [ .a ↦ v0
    , .b ↦ v0/a
    , .c ↦ v1/a ] ] -> [ GraphOfGraphsRealm.E.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .v0/a ↦ v0/a
    , .v1/a ↦ v1/a
    , .b ↦ b ] ])
    enforced GraphOfGraphsRealm.foreignKey.V.action := ∀ [ v0
    , v1
    , a
    , b
    , c ] ([ GraphOfGraphsRealm.V.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .b ↦ b
    , .c ↦ c ] ] -> [ (GraphOfGraphsRealm.V.base @ v0) []
    , (GraphOfGraphsRealm.V.base @ v1) []
    , (GraphOfGraphsRealm.E.base @ a) [.a ↦ v0, .b ↦ v1]
    , (GraphOfGraphsRealm.V.fiber @ b) [.a ↦ v0]
    , (GraphOfGraphsRealm.V.fiber @ c) [.a ↦ v1] ])
    monitored GraphOfGraphsRealm.total.V.action := ∀ [ v0
    , v1
    , a
    , b ] ([ (GraphOfGraphsRealm.V.base @ v0) []
    , (GraphOfGraphsRealm.V.base @ v1) []
    , (GraphOfGraphsRealm.E.base @ a) [.a ↦ v0, .b ↦ v1]
    , (GraphOfGraphsRealm.V.fiber @ b) [ .a ↦ v0 ] ] -> [ GraphOfGraphsRealm.V.action [ .v0 ↦ v0
    , .v1 ↦ v1
    , .a ↦ a
    , .b ↦ b ] ])
    enforced GraphOfGraphsRealm.foreignKey.E.base := ∀ [ a
    , b ] ([ GraphOfGraphsRealm.E.base [ .a ↦ a
    , .b ↦ b ] ] -> [ (GraphOfGraphsRealm.V.base @ a) []
    , (GraphOfGraphsRealm.V.base @ b) [] ])
    enforced GraphOfGraphsRealm.foreignKey.V.base := ∀ [  ] ([ GraphOfGraphsRealm.V.base [  ] ] -> [  ])
    enforced GraphOfGraphsRealm.foreignKey.E.fiber := ∀ [ a
    , b
    , c ] ([ GraphOfGraphsRealm.E.fiber [ .a ↦ a
    , .b ↦ b
    , .c ↦ c ] ] -> [ (GraphOfGraphsRealm.V.base @ a) []
    , (GraphOfGraphsRealm.V.fiber @ b) [.a ↦ a]
    , (GraphOfGraphsRealm.V.fiber @ c) [.a ↦ a] ])
    enforced GraphOfGraphsRealm.foreignKey.V.fiber := ∀ [ a ] ([ GraphOfGraphsRealm.V.fiber [ .a ↦ a ] ] -> [ (GraphOfGraphsRealm.V.base @ a) [  ] ])
  end
end

