-- elaborated
global entry named Graph
type: Theory
value: sig
  V : Set
  E : V -> V -> Set
end
realm named GraphRealm
generators: node
  V = rel []
  E = rel [a : GraphRealm.V [], b : GraphRealm.V []]
end
lowered: flatrealm
  entities
    table ℜ.E := [.a : ℜ.V, .b : ℜ.V]
    table ℜ.V := []
  end
  rules
    enforced ℜ.foreignKey.E a b := ℜ.E [ .a ↦ a
    , .b ↦ b ] ⊢ a ∈ ℜ.V [] ∧ b ∈ ℜ.V []
    enforced ℜ.foreignKey.V := ℜ.V [] ⊢ ⊤
  end
end

-- messages
