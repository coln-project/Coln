cabal-version: 3.4
name: coln-compiler
version: 0.1.0.0
license: (Apache-2.0 OR MIT)
maintainer: root@owenlynch.org
author: Owen Lynch
description: Elaborator and compiler for Coln
category: Language
build-type: Simple

library
  exposed-modules:
    Coln.Common
    Coln.Core.Conversion
    Coln.Core.Evaluation
    Coln.Core.Memoed
    Coln.Core.Params
    Coln.Core.Print
    Coln.Core.Readback
    Coln.Core.Syntax
    Coln.Core.Value
    Coln.Diagnostics
    Coln.Elaborator.Debug
    Coln.Elaborator.Diagnostics
    Coln.Elaborator.Environment
    Coln.Elaborator.Judgment
    Coln.Elaborator.Rules.Builtin
    Coln.Elaborator.Rules.Equality
    Coln.Elaborator.Rules.Function
    Coln.Elaborator.Rules.Record
    Coln.Elaborator.Rules.Universe
    Coln.Elaborator.Rules.Variable
    Coln.Frontend.Notation
    Coln.Frontend.Driver
    Coln.Frontend.Diagnostics
    Coln.Report

  hs-source-dirs: src
  default-language: GHC2024
  default-extensions:
    BlockArguments
    CPP
    DerivingVia
    DuplicateRecordFields
    FunctionalDependencies
    ImplicitParams
    MagicHash
    NoFieldSelectors
    OrPatterns
    OverloadedRecordDot
    OverloadedStrings
    PatternSynonyms
    QualifiedDo
    StrictData
    TemplateHaskell
    TypeData
    TypeFamilies
    TypeFamilyDependencies
    UnboxedSums
    UnboxedTuples
    UnicodeSyntax
    ViewPatterns

  ghc-options:
    -Wall
    -funbox-strict-fields
    -Wno-unused-imports
    -Wno-unused-top-binds
    -Wno-name-shadowing

  build-depends:
    base,
    bytestring,
    containers,
    diagnostician,
    directory,
    filepath,
    fnotation,
    hashable,
    prettyprinter,
    text,
    vector,
    vector-hashtables,

test-suite coln-compiler-test
  type: exitcode-stdio-1.0
  main-is: Main.hs
  hs-source-dirs: test
  default-language: GHC2024
  default-extensions:
    BlockArguments
    CPP
    DerivingVia
    FunctionalDependencies
    ImplicitParams
    MagicHash
    NoFieldSelectors
    OrPatterns
    OverloadedRecordDot
    OverloadedStrings
    PatternSynonyms
    QualifiedDo
    StrictData
    TemplateHaskell
    TypeData
    TypeFamilies
    TypeFamilyDependencies
    UnboxedSums
    UnboxedTuples
    UnicodeSyntax
    ViewPatterns

  ghc-options:
    -Wall
    -g

  build-depends:
    base,
    bytestring,
    containers,
    diagnostician,
    filepath,
    fnotation,
    coln-compiler,
    prettyprinter,
    tasty,
    tasty-golden,
    temporary >=1.3,
    text >=2.1.1,
    vector,
